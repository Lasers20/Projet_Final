@startuml STRMS_ClassDiagram
title STRMS - Class Diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam shadowing false
hide empty members

' ============== ENUMERATIONS ==============
enum TaskStatus {
  TODO
  BLOCKED
  IN_PROGRESS
  DONE
  + canTransitionTo(s: TaskStatus): boolean
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  + getWeight(): int
}

enum TaskCategory {
  BUGFIX
  FEATURE
  DOCUMENTATION
  RESEARCH
}

enum NotificationType {
  EMAIL
  SMS
  CONSOLE
}

' ============== USERS ==============
abstract class User {
  # id: String
  # name: String
  # email: String
  + {abstract} canCreateTask(): boolean
  + {abstract} canDeleteTask(): boolean
  + {abstract} canAssignTask(): boolean
  + {abstract} canExecuteTask(): boolean
  + {abstract} canGenerateReport(): boolean
  + {abstract} getRole(): String
}

class Admin
class Manager
class Engineer

User <|-- Admin
User <|-- Manager
User <|-- Engineer

' ============== TASKS ==============
class TaskHistoryEntry <<final>> {
  - action: String
  - performedBy: String
  - timestamp: LocalDateTime
  - description: String
  + toString(): String
}

class Task {
  - id: String
  - title: String
  - description: String
  - priority: PriorityLevel
  - status: TaskStatus
  - category: TaskCategory
  - deadline: LocalDate
  - engineer: Engineer
  - dependencies: List<Task>
  - history: List<TaskHistoryEntry>
  + updateStatus(s: TaskStatus): void
  + addHistoryEntry(e: TaskHistoryEntry): void
  + allDependenciesDone(): boolean
  + markAsDone(): void
  + changePriority(p: PriorityLevel): void
  + compareTo(other: Task): int
}

Task ..> TaskStatus
Task ..> PriorityLevel
Task ..> TaskCategory
Task "1" *-- "*" TaskHistoryEntry : history
Task "*" o-- "*" Task : dependencies
Task "*" --> "0..1" Engineer : assigned

' ============== MANAGER ==============
class TaskManager {
  - tasks: HashMap<String, Task>
  - users: HashMap<String, User>
  - inProgress: HashSet<Task>
  - readyQueue: PriorityQueue<Task>
  + addTask(t: Task, u: User): void
  + deleteTask(id: String, u: User): void
  + assignTask(id: String, e: Engineer, u: User): void
  + startTask(id: String, u: User): void
  + completeTask(id: String, u: User): void
  + addDependency(id: String, depId: String, u: User): void
  + removeDependency(id: String, depId: String, u: User): void
  + detectCircularDependency(src: Task, tgt: Task): boolean
  + findTask(id: String): Task
  + printInProgressTasks(): void
  + saveTasksToFile(path: String): void
  + loadTasksFromFile(path: String): void
}

TaskManager "1" *-- "*" Task
TaskManager "1" --> "*" User : manages
TaskManager ..> CircularDependencyException
TaskManager ..> DependencyNotCompletedException
TaskManager ..> TaskNotFoundException
TaskManager ..> InvalidRoleException
TaskManager ..> DuplicateTaskException
TaskManager ..> InvalidTaskStateException
TaskManager ..> FilePersistenceException

' ============== UTIL ==============
interface Reportable {
  + generateReport(): String
}

class ReportGenerator
class Dashboard
class FileManager
class NotificationManager

ReportGenerator ..|> Reportable
ReportGenerator --> TaskManager
Dashboard       --> TaskManager
NotificationManager ..> NotificationType
NotificationManager ..> User

' ============== EXCEPTIONS ==============
class CircularDependencyException <<Exception>>
class DependencyNotCompletedException <<Exception>>
class TaskNotFoundException <<Exception>>
class InvalidRoleException <<Exception>>
class FilePersistenceException <<Exception>>
class DuplicateTaskException <<Exception>>
class InvalidTaskStateException <<Exception>>

' ============== GUI ==============
class Main
class MainWindow
class LoginDialog
class TaskDialog

Main ..> TaskManager
Main ..> LoginDialog
Main ..> MainWindow
MainWindow ..> TaskManager
MainWindow ..> ReportGenerator
MainWindow ..> Dashboard
MainWindow ..> NotificationManager
LoginDialog ..> User

@enduml
