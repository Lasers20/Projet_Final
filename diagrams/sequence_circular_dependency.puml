@startuml STRMS_Sequence_CircularDependency
title Sequence Diagram - Circular Dependency Detection (Rejected)

actor "Alice (Admin)" as Alice
participant "MainWindow" as GUI
participant "TaskManager" as TM
participant "Task A" as TaskA
participant "Task C" as TaskC

note over TaskA, TaskC
  Existing graph:
    A -> B -> C  (linear, acyclic)
end note

Alice -> GUI : click "Add dependency" (A depends on C)
GUI -> TM : addDependency("A", "C", Alice)
activate TM
TM -> TM : verify alice.canCreateTask()
TM -> TM : detectCircularDependency(source=A, target=C)
note right
  DFS from C following its
  dependencies: C -> B -> A
  reaches A => cycle found
end note
TM -> TaskA : addHistoryEntry("DEPENDENCY_REJECTED", "Alice", "circular")
TM --> GUI : throw CircularDependencyException
deactivate TM
GUI --> Alice : Error dialog "circular dependency"

note over TaskA
  Graph remains unchanged.
  A still has no dependencies.
end note

@enduml
