@startuml STRMS_Sequence_Persistence
title Sequence Diagram - Save / Load / Report

actor "User" as U
participant "MainWindow" as GUI
participant "TaskManager" as TM
participant "FileSystem" as FS
participant "ReportGenerator" as RG
participant "FileManager" as FM

== Save ==
U -> GUI : click "Save"
GUI -> TM : saveTasksToFile("data/tasks.dat")
activate TM
TM -> FS : ObjectOutputStream.writeObject(tasks)
alt I/O failure
    TM --> GUI : throw FilePersistenceException
else
    TM --> GUI : ok
end
deactivate TM

== Load ==
U -> GUI : click "Load"
GUI -> TM : loadTasksFromFile("data/tasks.dat")
activate TM
TM -> FS : ObjectInputStream.readObject()
TM -> TM : rebuild inProgress / readyQueue
TM --> GUI : ok
deactivate TM

== Export Report ==
U -> GUI : click "Export Report"
GUI -> RG : generateReport()
activate RG
RG -> TM : listTasks() / listUsers()
RG --> GUI : report (String)
deactivate RG
GUI -> FM : writeText("data/report.txt", report)
FM -> FS : Files.write(...)
FM --> GUI : ok
GUI --> U : "Report exported"

@enduml
